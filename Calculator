<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Precision Calc | Modern Calculator</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      user-select: none; /* Prevents accidental selection on double-click */
    }

    body {
      background: linear-gradient(145deg, #1a2a3a 0%, #0f1a24 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Segoe UI', 'Inter', system-ui, -apple-system, 'Roboto', sans-serif;
      padding: 1.5rem;
    }

    /* Calculator card */
    .calculator {
      background: rgba(22, 32, 45, 0.85);
      backdrop-filter: blur(2px);
      border-radius: 3rem;
      box-shadow: 0 25px 45px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.1);
      padding: 1.8rem;
      width: 100%;
      max-width: 460px;
      transition: all 0.2s ease;
    }

    /* Display area */
    .display-wrapper {
      background: #0e1a1f;
      border-radius: 2rem;
      margin-bottom: 2rem;
      padding: 0.2rem;
      box-shadow: inset 0 4px 8px rgba(0, 0, 0, 0.5), 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .display {
      background: #0b1217;
      border-radius: 1.8rem;
      padding: 1.5rem 1.2rem;
      text-align: right;
      font-weight: 500;
      word-wrap: break-word;
      word-break: break-word;
      min-height: 130px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .previous-operand {
      font-size: 1.2rem;
      color: #7f8c8d;
      letter-spacing: 0.5px;
      min-height: 2rem;
      margin-bottom: 0.5rem;
      font-family: 'JetBrains Mono', monospace;
    }

    .current-operand {
      font-size: 2.9rem;
      font-weight: 600;
      color: #ecf0f1;
      line-height: 1.2;
      font-family: 'JetBrains Mono', monospace;
      word-break: break-word;
      letter-spacing: 1px;
    }

    /* Button grid */
    .buttons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.85rem;
    }

    button {
      border: none;
      background: #1e2e3b;
      font-size: 1.6rem;
      font-weight: 600;
      padding: 1.2rem 0;
      border-radius: 2rem;
      color: #eef4ff;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.15s ease;
      box-shadow: 0 5px 0 #0e151c;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    button:active {
      transform: translateY(3px);
      box-shadow: 0 2px 0 #0e151c;
    }

    /* Operator buttons */
    .operator {
      background: #e67e22;
      color: white;
      box-shadow: 0 5px 0 #b45d1a;
      font-size: 1.8rem;
    }

    .operator:active {
      transform: translateY(3px);
      box-shadow: 0 2px 0 #b45d1a;
    }

    /* Clear and delete special */
    .action-btn {
      background: #2c3e50;
      color: #f1c40f;
      box-shadow: 0 5px 0 #1a2a36;
      font-size: 1.3rem;
      font-weight: 600;
    }

    .equal-btn {
      background: #27ae60;
      box-shadow: 0 5px 0 #1e7948;
      color: white;
      font-size: 1.8rem;
    }

    .equal-btn:active {
      transform: translateY(3px);
      box-shadow: 0 2px 0 #1e7948;
    }

    /* number special glow */
    .number {
      background: #253b47;
      box-shadow: 0 5px 0 #17242e;
    }

    /* decimal button same as numbers */
    .decimal {
      background: #253b47;
      box-shadow: 0 5px 0 #17242e;
      font-size: 1.8rem;
    }

    /* hover effects desktop */
    @media (hover: hover) {
      button:hover {
        filter: brightness(1.08);
        transform: translateY(-2px);
        box-shadow: 0 7px 0 #0e151c;
      }
      button:active {
        transform: translateY(3px);
        box-shadow: 0 2px 0 #0e151c;
      }
      .operator:hover {
        background: #f39c12;
      }
      .equal-btn:hover {
        background: #2ecc71;
      }
    }

    /* footer tiny status */
    .key-hint {
      text-align: center;
      margin-top: 1.8rem;
      font-size: 0.7rem;
      color: #5d7a8c;
      font-weight: 400;
      letter-spacing: 0.3px;
      border-top: 1px solid #1f3846;
      padding-top: 1rem;
    }

    .key-hint span {
      background: #192f3a;
      padding: 0.2rem 0.5rem;
      border-radius: 8px;
      margin: 0 3px;
      font-family: monospace;
    }

    /* responsive */
    @media (max-width: 480px) {
      .calculator {
        padding: 1.2rem;
      }
      button {
        padding: 1rem 0;
        font-size: 1.4rem;
      }
      .current-operand {
        font-size: 2.2rem;
      }
      .buttons {
        gap: 0.7rem;
      }
    }
  </style>
</head>
<body>
<div class="calculator">
  <div class="display-wrapper">
    <div class="display">
      <div class="previous-operand" id="previousExpression"> </div>
      <div class="current-operand" id="currentValue">0</div>
    </div>
  </div>

  <div class="buttons">
    <!-- Row 1 -->
    <button class="action-btn" data-action="clear">AC</button>
    <button class="action-btn" data-action="delete">⌫</button>
    <button class="operator" data-op="%">%</button>
    <button class="operator" data-op="/">÷</button>

    <!-- Row 2 -->
    <button class="number" data-num="7">7</button>
    <button class="number" data-num="8">8</button>
    <button class="number" data-num="9">9</button>
    <button class="operator" data-op="*">×</button>

    <!-- Row 3 -->
    <button class="number" data-num="4">4</button>
    <button class="number" data-num="5">5</button>
    <button class="number" data-num="6">6</button>
    <button class="operator" data-op="-">−</button>

    <!-- Row 4 -->
    <button class="number" data-num="1">1</button>
    <button class="number" data-num="2">2</button>
    <button class="number" data-num="3">3</button>
    <button class="operator" data-op="+">+</button>

    <!-- Row 5 -->
    <button class="number" data-num="0">0</button>
    <button class="decimal" data-decimal=".">.</button>
    <button class="equal-btn" id="equalsBtn">=</button>
  </div>
  <div class="key-hint">
    💡 <span>⌨️ keyboard:</span> 0-9  ·  + - * /  ·  Enter  ·  Backspace  ·  Escape(AC)
  </div>
</div>

<script>
  // ---------- DOM Elements ----------
  const previousExpressionEl = document.getElementById('previousExpression');
  const currentValueEl = document.getElementById('currentValue');

  // State management
  let currentOperand = '0';       // string representation of current number
  let previousOperand = '';       // stored number before operator
  let operation = null;           // current operator (+, -, *, /, %)
  let shouldResetScreen = false;   // after '=' or operator pressed, next number replaces
  let lastResultWasError = false;  // flag to avoid weird behaviour after division by zero

  // Helper: format display number (trim unnecessary decimals but keep precision)
  function formatNumber(numberStr) {
    if (numberStr === '') return '';
    // convert to number to trim trailing zeros, but preserve big decimals?
    let num = parseFloat(numberStr);
    if (isNaN(num)) return 'Error';
    // if integer -> show integer without decimal
    if (Number.isInteger(num)) return num.toString();
    // limit decimal places to avoid overflow display, but keep up to 10 decimals
    let rounded = num.toFixed(10).replace(/\.?0+$/, '');
    return rounded;
  }

  // Update UI: current display + previous expression
  function updateDisplay() {
    // Display current operand, if error state don't override
    if (lastResultWasError && currentOperand === 'Error') {
      currentValueEl.textContent = 'Error';
      previousExpressionEl.textContent = '';
      return;
    }
    let displayValue = currentOperand;
    if (displayValue === '' || displayValue === undefined) displayValue = '0';
    // Format nicely to avoid scientific notation ugly
    let formattedCurrent = formatNumber(displayValue);
    currentValueEl.textContent = formattedCurrent;

    // Build previous expression section if operation exists
    if (operation !== null && previousOperand !== '' && !lastResultWasError) {
      let opSymbol = '';
      switch (operation) {
        case '+': opSymbol = '+'; break;
        case '-': opSymbol = '−'; break;
        case '*': opSymbol = '×'; break;
        case '/': opSymbol = '÷'; break;
        case '%': opSymbol = '%'; break;
        default: opSymbol = operation;
      }
      previousExpressionEl.textContent = `${formatNumber(previousOperand)} ${opSymbol}`;
    } else if (!lastResultWasError) {
      previousExpressionEl.textContent = '';
    } else if (currentOperand !== 'Error') {
      previousExpressionEl.textContent = '';
    }
  }

  // Reset calculator completely (AC)
  function allClear() {
    currentOperand = '0';
    previousOperand = '';
    operation = null;
    shouldResetScreen = false;
    lastResultWasError = false;
    updateDisplay();
  }

  // Delete last character
  function deleteLast() {
    if (lastResultWasError) {
      allClear();
      return;
    }
    if (shouldResetScreen) return;
    if (currentOperand.length === 1 || (currentOperand === '0')) {
      currentOperand = '0';
    } else {
      currentOperand = currentOperand.slice(0, -1);
      if (currentOperand === '' || currentOperand === '-') currentOperand = '0';
    }
    updateDisplay();
  }

  // Append number digit
  function appendNumber(number) {
    if (lastResultWasError) {
      allClear();
    }
    if (shouldResetScreen) {
      currentOperand = '';
      shouldResetScreen = false;
      lastResultWasError = false;
    }
    // Prevent multiple leading zeros
    if (currentOperand === '0' && number === '0') return;
    if (currentOperand === '0' && number !== '.') {
      currentOperand = number.toString();
    } else {
      currentOperand += number.toString();
    }
    updateDisplay();
  }

  // Append decimal point
  function appendDecimal() {
    if (lastResultWasError) {
      allClear();
    }
    if (shouldResetScreen) {
      currentOperand = '0';
      shouldResetScreen = false;
      lastResultWasError = false;
    }
    // if already contains dot, ignore
    if (currentOperand.includes('.')) return;
    // if empty or zero, start with "0."
    if (currentOperand === '' || currentOperand === '0') {
      currentOperand = '0.';
    } else {
      currentOperand += '.';
    }
    updateDisplay();
  }

  // Perform arithmetic operation based on stored values
  function computeResult() {
    if (operation === null || previousOperand === '' || shouldResetScreen) {
      // if no operation pending, but equal pressed, just keep current
      return false;
    }
    const prev = parseFloat(previousOperand);
    const curr = parseFloat(currentOperand);
    if (isNaN(prev) || isNaN(curr)) return false;

    let result;
    switch (operation) {
      case '+':
        result = prev + curr;
        break;
      case '-':
        result = prev - curr;
        break;
      case '*':
        result = prev * curr;
        break;
      case '/':
        if (curr === 0) {
          // division by zero -> error
          currentOperand = 'Error';
          previousOperand = '';
          operation = null;
          lastResultWasError = true;
          shouldResetScreen = true;
          updateDisplay();
          return false;
        }
        result = prev / curr;
        break;
      case '%':
        result = prev % curr;
        break;
      default:
        return false;
    }

    // Handle floating precision, trim to manageable length but keep exact
    if (isNaN(result) || !isFinite(result)) {
      currentOperand = 'Error';
      previousOperand = '';
      operation = null;
      lastResultWasError = true;
      shouldResetScreen = true;
      updateDisplay();
      return false;
    }

    // Convert result to string, avoid scientific notation for moderate numbers
    let resultString;
    if (Math.abs(result) > 1e12 || (Math.abs(result) < 1e-6 && result !== 0)) {
      resultString = result.toString();
    } else {
      // format with up to 12 decimal places without trailing zeros
      resultString = parseFloat(result.toFixed(10)).toString();
    }

    currentOperand = resultString;
    previousOperand = '';
    operation = null;
    shouldResetScreen = true;   // after showing result, next number starts fresh
    lastResultWasError = false;
    updateDisplay();
    return true;
  }

  // Choose operator (+, -, *, /, %)
  function setOperator(op) {
    if (lastResultWasError) {
      allClear();
    }
    // If there's a pending operation and currentOperand is valid, compute previous first
    if (operation !== null && previousOperand !== '' && !shouldResetScreen) {
      // perform intermediate calculation
      const prevVal = parseFloat(previousOperand);
      const currVal = parseFloat(currentOperand);
      if (!isNaN(prevVal) && !isNaN(currVal)) {
        let tempResult;
        switch (operation) {
          case '+': tempResult = prevVal + currVal; break;
          case '-': tempResult = prevVal - currVal; break;
          case '*': tempResult = prevVal * currVal; break;
          case '/': 
            if (currVal === 0) {
              currentOperand = 'Error';
              previousOperand = '';
              operation = null;
              lastResultWasError = true;
              shouldResetScreen = true;
              updateDisplay();
              return;
            }
            tempResult = prevVal / currVal; 
            break;
          case '%': tempResult = prevVal % currVal; break;
          default: tempResult = currVal;
        }
        if (isNaN(tempResult) || !isFinite(tempResult)) {
          currentOperand = 'Error';
          previousOperand = '';
          operation = null;
          lastResultWasError = true;
          shouldResetScreen = true;
          updateDisplay();
          return;
        }
        currentOperand = tempResult.toString();
      }
    }
    // set new operation: store current operand as previous, clear for next entry
    if (currentOperand === 'Error') {
      allClear();
      return;
    }
    previousOperand = currentOperand;
    operation = op;
    shouldResetScreen = true;   // next number entry overwrites current display
    lastResultWasError = false;
    updateDisplay();
  }

  // Special handling for percentage as unary/binary: we follow standard: a % b -> remainder,
  // but also if no previous operand, treat like modulo? Already implemented via binary.
  // For UX: ensure % works with our state.
  // Edge fix: after operator and before second number, if operator changed

  // Event listener for buttons
  function handleButtonClick(e) {
    const target = e.target;
    const isButton = target.tagName === 'BUTTON';
    if (!isButton) return;

    // Number buttons
    if (target.hasAttribute('data-num')) {
      const num = target.getAttribute('data-num');
      appendNumber(num);
    }
    // Decimal button
    else if (target.hasAttribute('data-decimal')) {
      appendDecimal();
    }
    // Operator buttons (+, -, *, /, %)
    else if (target.hasAttribute('data-op')) {
      let op = target.getAttribute('data-op');
      // Map display symbols to internal operators
      if (op === '÷') op = '/';
      if (op === '×') op = '*';
      if (op === '−') op = '-';
      setOperator(op);
    }
    // Clear action (AC)
    else if (target.getAttribute('data-action') === 'clear') {
      allClear();
    }
    // Delete action (backspace)
    else if (target.getAttribute('data-action') === 'delete') {
      deleteLast();
    }
    // Equals button
    else if (target.id === 'equalsBtn') {
      if (lastResultWasError) {
        allClear();
      } else {
        computeResult();
      }
    }
  }

  // ----- KEYBOARD SUPPORT (Bonus) -----
  function handleKeyboard(e) {
    const key = e.key;
    // Prevent triggering input events on page scroll etc
    const validKeys = /[\d\+\-\*\/\%\.\r\b\Escape\=]/;
    if (!validKeys.test(key) && key !== 'Backspace' && key !== 'Enter' && key !== 'Escape' && key !== 'Delete') return;

    e.preventDefault(); // Avoid any page refresh or unintended interactions

    // Numbers 0-9
    if (/^[0-9]$/.test(key)) {
      appendNumber(key);
    }
    // Decimal point
    else if (key === '.') {
      appendDecimal();
    }
    // Operators + - * / %
    else if (key === '+') {
      setOperator('+');
    } else if (key === '-') {
      setOperator('-');
    } else if (key === '*') {
      setOperator('*');
    } else if (key === '/') {
      setOperator('/');
    } else if (key === '%') {
      setOperator('%');
    }
    // Enter or = key (compute)
    else if (key === 'Enter' || key === '=') {
      if (lastResultWasError) {
        allClear();
      } else {
        computeResult();
      }
    }
    // Backspace / Delete (delete last)
    else if (key === 'Backspace' || key === 'Delete') {
      deleteLast();
    }
    // Escape (Clear All)
    else if (key === 'Escape') {
      allClear();
    }
  }

  // attach events
  const buttonsContainer = document.querySelector('.buttons');
  buttonsContainer.addEventListener('click', handleButtonClick);
  window.addEventListener('keydown', handleKeyboard);

  // Initialize display
  updateDisplay();

  // Extra polish: if any abnormal floating, ensure error recovery
  // handle edge behavior: if user clicks operator right after equal, it uses the result as previousOperand
  // setOperator already handles with shouldResetScreen logic with clear flags.
  // Final fix: after clear, shouldResetScreen false.
</script>
</body>
</html>
